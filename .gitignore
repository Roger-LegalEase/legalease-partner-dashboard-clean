# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

tmp/*
# RCAP all-50 QA/attorney review handoff artifacts are committed for team review.
# Only the all50 review-inbox subtree is tracked; other tmp/review-inbox output
# (e.g. overlay-factory candidates) stays ignored.
!tmp/review-inbox/
tmp/review-inbox/*
!tmp/review-inbox/all50/

# Local official PDF forms - do not commit
private/
*.zip
data/record-clearing/pdf-inspection/latest-report.json
data/record-clearing/pdf-inspection/latest-report.md
data/record-clearing/pdf-inspection/migration-triage.json
data/record-clearing/pdf-inspection/migration-triage.md
tmp/record-clearing-shadow/
