{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expungement.ai/schemas/state-flow-profile.schema.json",
  "title": "Expungement.ai jurisdiction rule-level frontend profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "jurisdiction",
    "source",
    "terminology",
    "flowStages",
    "questions",
    "pathways",
    "orderedDecisionRules",
    "packetGenerator",
    "copyGuardrails",
    "qa"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "profileVersion": {
      "type": "string"
    },
    "jurisdiction": {
      "type": "object",
      "required": [
        "code",
        "name",
        "slug"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object"
    },
    "terminology": {
      "type": "object"
    },
    "flowStages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "questions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "stage",
          "prompt",
          "type",
          "required",
          "source"
        ]
      }
    },
    "pathways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "summary",
          "sourceRef",
          "suggestedResultCode"
        ]
      }
    },
    "orderedDecisionRules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "priority",
          "stage",
          "when",
          "then",
          "sourceRef"
        ]
      }
    },
    "waitingPeriodRules": {
      "type": "array"
    },
    "exclusionRules": {
      "type": "array"
    },
    "packetGenerator": {
      "type": "object",
      "required": [
        "architecture",
        "legacyGeneratorAllowed",
        "genericLegalFallbackAllowed",
        "pathways",
        "requiredInputs"
      ]
    },
    "copyGuardrails": {
      "type": "array",
      "minItems": 4
    },
    "sourceSections": {
      "type": "array"
    },
    "frontendContract": {
      "type": "object"
    },
    "qa": {
      "type": "object"
    }
  }
}
